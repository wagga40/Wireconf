# Load env file from argv before other parsing so defaults apply, then CLI can override.
# Falls back to wireconf.env in $PWD when no explicit -e is given.
wireconf_bootstrap_env_from_argv() {
  local -a argv=("$@")
  local i
  for ((i = 0; i < ${#argv[@]}; i++)); do
    if [[ "${argv[$i]}" == "--env-file" || "${argv[$i]}" == "-e" ]]; then
      local j=$((i + 1))
      [[ "$j" -lt ${#argv[@]} ]] || die "-e/--env-file needs a path"
      WC_ENV_FILE="${argv[$j]}"
      WC_ENV_FILE_EXPLICIT=1
      load_env_file "$WC_ENV_FILE"
      return 0
    fi
  done
  if [[ -f "${PWD}/wireconf.env" ]]; then
    WC_ENV_FILE="${PWD}/wireconf.env"
    load_env_file "$WC_ENV_FILE"
    log_info "Auto-loaded ${PWD}/wireconf.env (use -e to override)"
  fi
  return 0
}

wireconf_run_plan_prechecks() {
  printf '\n' >&2
  log_info "Operator basics (ssh, scp, awk, bash)..."
  plan_check_operator_basics || die "Operator machine is missing required commands."
  printf '\n' >&2
  log_info "SSH connectivity..."
  plan_check_ssh_connectivity || die "SSH connectivity check failed."
  printf '\n' >&2
  log_info "Debian/Ubuntu on each inventory host..."
  plan_check_debian_family_all || die "OS check failed (wireconf targets Debian-family only)."
  printf '\n' >&2
  log_info "WireGuard key generation (operator or hub)..."
  plan_check_operator_wg_keygen || die "WireGuard tools / keygen check failed."
  printf '\n' >&2
  log_info "Tools on each target (sudo)..."
  plan_check_target_tools || die "Target tool check failed."
}

wireconf_plan() {
  local i st
  log_info "Interface: ${WC_IFACE}  Network: ${WC_NETWORK}  Port: ${WC_PORT}"
  if wc_resolve_hub_endpoint_from_inventory; then
    log_warn "WG_HUB_ENDPOINT / --hub-endpoint not set: remote peers will use the inventory hub host (${WC_HUB_ENDPOINT}) as WireGuard Endpoint=; set WG_HUB_ENDPOINT or -H explicitly if peers cannot reach that address."
  fi
  wc_warn_if_network_collides
  log_info "Hub endpoint (for peers): ${WC_HUB_ENDPOINT:-<unset>}"
  log_info "Auto start at boot: $(normalize_bool "$WC_AUTO_START")"
  log_info "Default full tunnel: $(normalize_bool "$WC_FULL_TUNNEL_DEFAULT")"
  log_info "Default SSH port: ${WC_SSH_PORT_DEFAULT}"
  wireconf_run_plan_prechecks
  printf '\n' >&2
  wc_build_ip_map
  log_info "Allocated VPN addresses:"
  for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
    log_detail "[${i}] ${WC_SSH_TARGETS[$i]}  ssh_port=${WC_SSH_PORTS[$i]}  ip=${WC_INDEX_TO_IP[$i]}  full_tunnel=${WC_FULL_TUNNEL[$i]}"
  done
  printf '\n' >&2
  if any_full_tunnel_peer; then
    log_info "Hub config will include NAT/forwarding PostUp (full-tunnel peer(s) present)."
  else
    log_info "Hub config without NAT PostUp (split-tunnel peers only)."
  fi
  printf '\n' >&2
  log_info "Preflight (existing conf / interface up):"
  for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
    st="$(preflight_plan_hint "${WC_SSH_TARGETS[$i]}")"
    log_detail "${WC_SSH_TARGETS[$i]}  conf_or_iface: ${st}"
  done
}

wireconf_apply() {
  wc_require_hub_endpoint_for_apply
  log_info "Running plan prechecks (same order as plan)..."
  wireconf_run_plan_prechecks
  wc_build_ip_map
  if ! wc_apply_prepare_prompts; then
    return 1
  fi
  wc_apply_collect_removed_hosts
  wc_apply_teardown_removed_hosts
  preflight_all_hosts
  local i jobs=0 max_j="${WC_PARALLEL:-1}"
  [[ "$max_j" =~ ^[0-9]+$ ]] && [[ "$max_j" -ge 1 ]] || max_j=1
  wg_build_all

  if [[ "$max_j" -gt 1 ]]; then
    log_info "Deploying configs (parallel=${max_j})..."
    for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
      wc_scp_to "${WC_SSH_TARGETS[$i]}" "$(wg_conf_path_for_index "$i")" "/etc/wireguard/${WC_IFACE}.conf" &
      jobs=$((jobs + 1))
      if [[ "$jobs" -ge "$max_j" ]]; then
        wait -n || die "Config upload failed"
        jobs=$((jobs - 1))
      fi
    done
    wait || die "Config upload failed"
  else
    for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
      wc_scp_to "${WC_SSH_TARGETS[$i]}" "$(wg_conf_path_for_index "$i")" "/etc/wireguard/${WC_IFACE}.conf"
    done
  fi

  local autostart
  autostart="$(normalize_bool "$WC_AUTO_START")"
  jobs=0
  if [[ "$max_j" -gt 1 ]]; then
    for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
      (
        idx="$i"
        if [[ "$autostart" == "yes" ]]; then
          wg_systemd_set_autostart "${WC_SSH_TARGETS[$idx]}" yes
        else
          wc_run_sudo "${WC_SSH_TARGETS[$idx]}" "wg-quick down $(printf '%q' "$WC_IFACE") 2>/dev/null || true"
          if [[ "${WC_APPLY_BRING_UP[$idx]}" -eq 1 ]]; then
            wc_run_sudo "${WC_SSH_TARGETS[$idx]}" "wg-quick up $(printf '%q' "/etc/wireguard/${WC_IFACE}.conf")"
          else
            log_info "Skipping wg-quick up on ${WC_SSH_TARGETS[$idx]} (${WC_IFACE} stays down)."
          fi
        fi
      ) &
      jobs=$((jobs + 1))
      if [[ "$jobs" -ge "$max_j" ]]; then
        wait -n || die "Bring-up failed"
        jobs=$((jobs - 1))
      fi
    done
    wait || die "Bring-up failed"
  else
    for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
      if [[ "$autostart" == "yes" ]]; then
        wg_systemd_set_autostart "${WC_SSH_TARGETS[$i]}" yes
      else
        wc_run_sudo "${WC_SSH_TARGETS[$i]}" "wg-quick down $(printf '%q' "$WC_IFACE") 2>/dev/null || true"
        if [[ "${WC_APPLY_BRING_UP[$i]}" -eq 1 ]]; then
          wc_run_sudo "${WC_SSH_TARGETS[$i]}" "wg-quick up $(printf '%q' "/etc/wireguard/${WC_IFACE}.conf")"
        else
          log_info "Skipping wg-quick up on ${WC_SSH_TARGETS[$i]} (${WC_IFACE} stays down)."
        fi
      fi
    done
  fi

  wg_cleanup_stage
  trap - EXIT
  wc_log_write_last_apply_state
  wc_log_action apply "iface=${WC_IFACE} hosts=$(wc_log_hosts_csv)"
  wc_log_cleanup_legacy
  log_info "apply completed."
}

