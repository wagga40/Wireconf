# One-shot: plan prechecks + apply + verify. Honors -y, parallel, etc.
wireconf_up() {
  wireconf_plan
  printf '\n' >&2
  log_info "up: running apply..."
  wireconf_apply
  printf '\n' >&2
  log_info "up: running verify..."
  wireconf_verify
  printf '\n' >&2
  log_info "up: done."
}

