wireconf_show() {
  wc_build_ip_map
  plan_check_operator_wg_keygen || die "WireGuard tools / keygen check failed."
  wg_build_all
  local i n="${#WC_SSH_TARGETS[@]}"
  if [[ "${WC_SHOW_REDACT:-0}" -eq 1 ]]; then
    log_info "show: PrivateKey lines are redacted (--redact)."
  else
    log_warn "show: full configs go to stdout and include PrivateKey — avoid logs and untrusted pipes; use --redact to omit secrets."
  fi
  for ((i = 0; i < n; i++)); do
    local label="hub"
    [[ "$i" -gt 0 ]] && label="peer $i"
    printf '### %s — %s (VPN %s) ###\n' "$label" "${WC_SSH_TARGETS[$i]}" "${WC_INDEX_TO_IP[$i]}"
    if [[ "${WC_SHOW_REDACT:-0}" -eq 1 ]]; then
      sed 's/^PrivateKey[[:space:]]*=.*/PrivateKey = <redacted>/' "$(wg_conf_path_for_index "$i")"
    else
      cat "$(wg_conf_path_for_index "$i")"
    fi
    printf '\n'
  done
  wg_cleanup_stage
  trap - EXIT
}

wireconf_teardown() {
  local i
  log_info "Tearing down ${WC_IFACE} on all inventory hosts..."
  for ((i = 0; i < ${#WC_SSH_TARGETS[@]}; i++)); do
    local t="${WC_SSH_TARGETS[$i]}"
    log_info "Stopping ${WC_IFACE} on ${t}..."
    wg_teardown_on_host "$t" "$WC_FORCE"
    if [[ "$WC_FORCE" -eq 1 ]]; then
      log_detail "${t}: removed /etc/wireguard/${WC_IFACE}.conf"
    fi
  done
  wc_log_action teardown "iface=${WC_IFACE} hosts=$(wc_log_hosts_csv)"
  if [[ "$WC_FORCE" -eq 0 ]]; then
    log_info "teardown: services stopped and disabled. Config files left in place (use -f to remove)."
  else
    log_info "teardown: services stopped, disabled, and config files removed."
  fi
}

# Copy examples into $PWD; never overwrite existing paths (-e = path exists).
wireconf_init_fixup_env() {
  local f="$1" tmp
  [[ -f "$f" ]] || return 0
  if grep -q '^INVENTORY=examples/inventory\.example$' "$f" 2>/dev/null; then
    tmp="${f}.tmp.$$"
    sed 's|^INVENTORY=examples/inventory\.example$|INVENTORY=inventory|' "$f" >"$tmp"
    mv "$tmp" "$f"
    log_info "Set INVENTORY=inventory in wireconf.env (local inventory file)"
  fi
}

# Source tree: return ${WIRECONF_ROOT}/examples.
# Single-file build: replaced by scripts/build-single-file.sh with a version
# that writes embedded heredocs into a fresh tempdir.
# WIRECONF_EMBED_EXAMPLES_START
wc_embedded_examples_dir() {
  echo "${WIRECONF_ROOT}/examples"
}
# WIRECONF_EMBED_EXAMPLES_END

wireconf_cmd_init() {
  local exdir
  exdir="$(wc_embedded_examples_dir)"
  local created=0
  [[ -d "$exdir" ]] || die "Examples directory not found: ${exdir} (wrong WIRECONF_ROOT?)"
  log_info "init: target directory is ${PWD}"

  if [[ -e "${PWD}/inventory" ]]; then
    log_warn "Skip inventory — already exists: ${PWD}/inventory"
  else
    [[ -f "${exdir}/inventory.example" ]] || die "Missing ${exdir}/inventory.example"
    cp -p "${exdir}/inventory.example" "${PWD}/inventory"
    log_info "Created ${PWD}/inventory"
    created=$((created + 1))
  fi

  if [[ -e "${PWD}/wireconf.env" ]]; then
    log_warn "Skip wireconf.env — already exists: ${PWD}/wireconf.env"
  else
    [[ -f "${exdir}/wireconf.env.example" ]] || die "Missing ${exdir}/wireconf.env.example"
    cp -p "${exdir}/wireconf.env.example" "${PWD}/wireconf.env"
    wireconf_init_fixup_env "${PWD}/wireconf.env"
    log_info "Created ${PWD}/wireconf.env"
    created=$((created + 1))
  fi

  if [[ "$created" -eq 0 ]]; then
    log_warn "init: no files written. Remove or rename existing files to copy examples."
  else
    log_info "init: done. Edit inventory and wireconf.env, then: ./wireconf plan"
  fi
}

# Remove local working files: resolved INVENTORY (or ./inventory), ${basename}.wireconf.* next to it, ./wireconf.env.
wireconf_cmd_clean() {
  local inv invdir invbase envf p
  local -a rm_paths=()

  inv="${WC_INVENTORY:-}"
  if [[ -z "$inv" ]]; then
    inv="${PWD}/inventory"
  elif [[ "$inv" != /* ]]; then
    inv="${PWD}/${inv#./}"
  fi
  invdir="$(dirname -- "$inv")"
  invbase="$(basename -- "$inv")"
  envf="${PWD}/wireconf.env"

  [[ -e "$inv" ]] && rm_paths+=("$inv")
  shopt -s nullglob
  for p in "${invdir}/${invbase}.wireconf."*; do
    [[ -e "$p" ]] && rm_paths+=("$p")
  done
  shopt -u nullglob
  [[ -e "$envf" ]] && rm_paths+=("$envf")

  if [[ "${#rm_paths[@]}" -eq 0 ]]; then
    log_info "clean: nothing to remove (no ${inv}, no ${invdir}/${invbase}.wireconf.*, no ${envf})."
    return 0
  fi
  log_info "clean: will remove in ${PWD}:"
  local p
  for p in "${rm_paths[@]}"; do
    log_detail "$p"
  done
  if [[ "${WC_ASSUME_YES:-0}" -ne 1 ]] && [[ ! -t 2 ]]; then
    log_err "clean: need an interactive terminal (stderr) to confirm, or use -y / WIRECONF_YES=1"
    exit 1
  fi
  if ! wireconf_prompt_yes "Remove these files?"; then
    log_info "clean: cancelled."
    return 0
  fi
  for p in "${rm_paths[@]}"; do
    rm -f "$p"
    log_info "Removed $p"
  done
  log_info "clean: done."
}

# Parse argv: optional global flags, then subcommand. Unknown flags error.
parse_cli() {
  WC_SUBCMD=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      -V | --version)
        printf 'wireconf %s\n' "$WIRECONF_VERSION"
        exit 0
        ;;
      -e | --env-file)
        if [[ "$WC_ENV_FILE_EXPLICIT" -eq 1 ]]; then
          log_warn "Multiple -e/--env-file flags; only the first was sourced (ignoring $2)"
        fi
        WC_ENV_FILE="$2"
        shift 2
        ;;
      -I | --inventory)
        WC_INVENTORY="$2"
        WC_INVENTORY_EXPLICIT=1
        shift 2
        ;;
      -n | --iface)
        WC_IFACE="$2"
        shift 2
        ;;
      -c | --network)
        WC_NETWORK="$2"
        shift 2
        ;;
      -H | --hub-endpoint)
        WC_HUB_ENDPOINT="$2"
        shift 2
        ;;
      -p | --port)
        WC_PORT="$2"
        shift 2
        ;;
      -S | --ssh-port)
        validate_ssh_port "$2"
        WC_SSH_PORT_DEFAULT="$2"
        shift 2
        ;;
      --ssh-accept-new)
        WC_SSH_ACCEPT_NEW=yes
        shift
        ;;
      -a | --auto-start)
        WC_AUTO_START="$2"
        shift 2
        ;;
      -t | --full-tunnel-default)
        WC_FULL_TUNNEL_DEFAULT="$2"
        shift 2
        ;;
      -k | --keepalive)
        WC_KEEPALIVE="$2"
        shift 2
        ;;
      --parallel)
        WC_PARALLEL="$2"
        shift 2
        ;;
      -f | --force)
        WC_FORCE=1
        shift
        ;;
      -b | --backup-dir)
        WC_BACKUP_DIR="$2"
        shift 2
        ;;
      -y | --yes)
        WC_ASSUME_YES=1
        shift
        ;;
      --redact)
        WC_SHOW_REDACT=1
        shift
        ;;
      plan | apply | show | verify | test | status | teardown | init | clean | update)
        WC_SUBCMD="$1"
        [[ "$WC_SUBCMD" == "test" ]] && WC_SUBCMD="verify"
        shift
        break
        ;;
      up | doctor | bootstrap | add-peer | remove-peer)
        WC_SUBCMD="$1"
        shift
        break
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        die "Unexpected argument: $1 (put global flags before the subcommand)"
        ;;
    esac
  done
  if [[ -z "${WC_SUBCMD:-}" ]]; then
    usage
    exit 1
  fi
  case "${WC_SUBCMD}" in
    up | doctor | bootstrap | add-peer | remove-peer)
      # Global array (do not use declare -a here — it would be local to parse_cli)
      WC_CMD_EXTRA_ARGS=("$@")
      ;;
    *)
      if [[ $# -gt 0 ]]; then
        die "Trailing arguments: $*"
      fi
      ;;
  esac
}

# If -I was not passed and INVENTORY is unset, default WC_INVENTORY to ./inventory
# when that file actually exists. Returns 0 if a path is now set, 1 otherwise.
wc_resolve_default_inventory() {
  [[ -n "${WC_INVENTORY:-}" ]] && return 0
  [[ -f "${PWD}/inventory" ]] || return 1
  WC_INVENTORY="${PWD}/inventory"
  log_info "Using ./inventory (no -I/--inventory or INVENTORY env var given)"
  return 0
}

main() {
  wireconf_common_init
  printf '\n' >&2
  wireconf_print_banner
  # Fast-path for help/version: skip env loading entirely
  case "${1:-}" in
    -h | --help) usage; exit 0 ;;
    -V | --version) printf 'wireconf %s\n' "$WIRECONF_VERSION"; exit 0 ;;
  esac
  wireconf_bootstrap_env_from_argv "$@"
  parse_cli "$@"
  wc_apply_ssh_hostkey_opts
  if [[ "${WC_SUBCMD}" == "init" ]]; then
    wireconf_cmd_init
    exit 0
  fi
  if [[ "${WC_SUBCMD}" == "clean" ]]; then
    wireconf_cmd_clean
    exit 0
  fi
  if [[ "${WC_SUBCMD}" == "update" ]]; then
    wireconf_cmd_update
    exit $?
  fi

  # `up` with inline HOST args bypasses the inventory file entirely (stateless).
  if [[ "${WC_SUBCMD}" == "up" ]] && [[ "${#WC_CMD_EXTRA_ARGS[@]}" -gt 0 ]]; then
    if [[ "${WC_INVENTORY_EXPLICIT:-0}" -eq 1 ]]; then
      die "up: cannot combine -I/--inventory with inline HOST arguments (pick one)"
    fi
    wc_load_inline_hosts "${WC_CMD_EXTRA_ARGS[@]}"
    WC_INVENTORY=""
    log_info "up: inline mode — state is not persisted (no action log, no last-state). Use an inventory file to get drift detection."
    validate_cidr "$WC_NETWORK"
    wc_validate_runtime_config
    wireconf_up
    exit 0
  fi

  # `doctor` accepts inline HOSTs too; no inventory file is required for a single-shot diagnostic.
  if [[ "${WC_SUBCMD}" == "doctor" ]] && [[ "${#WC_CMD_EXTRA_ARGS[@]}" -gt 0 ]]; then
    if [[ "${WC_INVENTORY_EXPLICIT:-0}" -eq 1 ]]; then
      die "doctor: cannot combine -I/--inventory with inline HOST arguments (pick one)"
    fi
    wc_load_inline_hosts "${WC_CMD_EXTRA_ARGS[@]}"
    WC_INVENTORY=""
    wireconf_doctor
    exit $?
  fi

  # `bootstrap` also accepts inline HOSTs (same stateless rules as up/doctor).
  if [[ "${WC_SUBCMD}" == "bootstrap" ]] && [[ "${#WC_CMD_EXTRA_ARGS[@]}" -gt 0 ]]; then
    if [[ "${WC_INVENTORY_EXPLICIT:-0}" -eq 1 ]]; then
      die "bootstrap: cannot combine -I/--inventory with inline HOST arguments (pick one)"
    fi
    wc_load_inline_hosts "${WC_CMD_EXTRA_ARGS[@]}"
    WC_INVENTORY=""
    wireconf_bootstrap
    exit $?
  fi

  wc_resolve_default_inventory || true
  [[ -n "${WC_INVENTORY:-}" ]] || die "Set -I/--inventory, INVENTORY in env file, or pass HOSTs inline to \`up\`. Alternatively, run \`wireconf init\` first."
  if [[ "${WC_SUBCMD}" == "add-peer" ]]; then
    inventory_peer_add "$WC_INVENTORY" "${WC_CMD_EXTRA_ARGS[@]}"
    wc_log_action add-peer "host=${WC_CMD_EXTRA_ARGS[0]}"
    exit 0
  fi
  if [[ "${WC_SUBCMD}" == "remove-peer" ]]; then
    [[ ${#WC_CMD_EXTRA_ARGS[@]} -eq 1 ]] || die "remove-peer: need exactly one HOST argument"
    inventory_peer_remove "$WC_INVENTORY" "${WC_CMD_EXTRA_ARGS[0]}"
    wc_log_action remove-peer "host=${WC_CMD_EXTRA_ARGS[0]}"
    exit 0
  fi
  parse_inventory "$WC_INVENTORY"
  validate_cidr "$WC_NETWORK"
  wc_validate_runtime_config

  case "${WC_SUBCMD}" in
    up) wireconf_up ;;
    doctor) wireconf_doctor ;;
    bootstrap) wireconf_bootstrap ;;
    plan) wireconf_plan ;;
    apply) wireconf_apply ;;
    show) wireconf_show ;;
    verify) wireconf_verify ;;
    status) wireconf_status ;;
    teardown) wireconf_teardown ;;
    *) die "Unknown command: ${WC_SUBCMD}" ;;
  esac
}

if [[ "${WIRECONF_SOURCE_ONLY:-0}" != "1" ]]; then
  main "$@"
fi
