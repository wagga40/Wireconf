# Copy to wireconf.env and adjust. wireconf auto-loads ./wireconf.env if present,
# or pass explicitly: ./wireconf -e wireconf.env ...  (-e = --env-file)

# Host inventory (first line = hub). Overrides with: --inventory path
INVENTORY=examples/inventory.example

# Logical WireGuard interface name and config file basename (e.g. /etc/wireguard/wg0.conf)
WG_INTERFACE=wg0

# VPN IPv4 CIDR. Hub gets .1, peers get .2, .3, ...
WG_NETWORK=10.200.0.0/24

# UDP port on the hub (must be reachable from peers)
WG_PORT=51820

# Public IP or DNS name of the hub as seen by peers (required for remote peers).
# Uncomment and set this before running apply:
# WG_HUB_ENDPOINT=203.0.113.10

# Optional: egress interface on hub for NAT (full-tunnel peers). If empty, PostUp detects default route.
# WG_HUB_EGRESS=eth0

# Enable wg-quick@ on boot after apply (yes|no)
AUTO_START=yes

# Default full-tunnel for peers when not set per line in inventory (yes|no)
FULL_TUNNEL_DEFAULT=no

# PersistentKeepalive for peers in seconds (0 = disabled, default 25)
# WG_KEEPALIVE=25

# Optional MTU for all WireGuard interfaces (useful for PPPoE / VPN-over-VPN)
# WG_MTU=1420

# Non-interactive: skip apt wireguard prompts and `clean` confirmation (same as CLI -y/--yes)
# WIRECONF_YES=1

# Default SSH port when not set per inventory line (1–65535)
# SSH_PORT=22

# Auto-append new SSH host keys to known_hosts (StrictHostKeyChecking=accept-new; yes|no; CLI: --ssh-accept-new)
# SSH_ACCEPT_NEW=no

# Extra ssh(1) options, e.g. -i ~/.ssh/id_ed25519 (avoid duplicate -p here; use SSH_PORT / inventory)
# SSH_OPTS=

# Optional DNS pushed to full-tunnel peers (WireGuard [Interface] DNS=)
# WG_PEER_DNS=1.1.1.1

# Optional DNS pushed to split-tunnel peers (for internal name resolution over VPN)
# WG_SPLIT_DNS=10.200.0.1

# Stale handshake threshold for verify/status in seconds (default 300)
# WG_HANDSHAKE_TIMEOUT=300

# Concurrent SSH operations during apply (default 1 = sequential)
# WG_PARALLEL=1
